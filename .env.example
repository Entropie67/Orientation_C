# Copier ce fichier en .env.local et remplir les valeurs

# Clé API OpenRouter — active le bloc "Avis de l'IA" sur la page résultat
# Sans cette clé, l'app fonctionne en mode local pur (moteur de règles)
# Obtenir une clé : https://openrouter.ai > Settings > API Keys
VITE_OPENROUTER_API_KEY=

# Modèle à utiliser (défaut : anthropic/claude-3-haiku)
# Autres options : openai/gpt-4o-mini | mistralai/mistral-7b-instruct
VITE_OPENROUTER_MODEL=anthropic/claude-3-haiku

# URL de l'app (pour les headers OpenRouter)
VITE_APP_URL=http://localhost:5173
